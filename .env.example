# ── Backend Database Keys ──
# Server-side variables (read by server.ts via dotenv)
# Find these in your Supabase Dashboard > Settings > API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your-supabase-service-role-key"

# ── Frontend Client Variables ──
# VITE-prefixed variables (injected by Vite into the browser bundle)
# Use the "anon public" key from Supabase Dashboard > Settings > API
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
